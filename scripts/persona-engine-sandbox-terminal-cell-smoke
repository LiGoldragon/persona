#!/usr/bin/env bash
set -euo pipefail

: "${PERSONA_BASH:?PERSONA_BASH must point at bash}"
: "${TERMINAL_CELL_DAEMON:?TERMINAL_CELL_DAEMON must point at terminal-cell-daemon}"
: "${TERMINAL_CELL_SEND:?TERMINAL_CELL_SEND must point at terminal-cell-send}"
: "${TERMINAL_CELL_WAIT:?TERMINAL_CELL_WAIT must point at terminal-cell-wait}"
: "${TERMINAL_CELL_CAPTURE:?TERMINAL_CELL_CAPTURE must point at terminal-cell-capture}"
: "${TERMINAL_CELL_VIEW:?TERMINAL_CELL_VIEW must point at terminal-cell-view}"
: "${PERSONA_ENGINE_SANDBOX_ATTACH:?PERSONA_ENGINE_SANDBOX_ATTACH must point at persona-engine-sandbox-attach}"

sandbox_dir=""
harness="pi"

usage() {
  cat <<'EOF'
usage: persona-engine-sandbox-terminal-cell-smoke --sandbox-dir DIR [--harness pi|pi-tools|pi-message-router|pi-managed-harness|fixture]

Starts terminal-cell-daemon at DIR/run/cell.sock, runs one child harness inside
the PTY, drives it through terminal-cell clients, and leaves inspectable
artifacts under DIR/artifacts.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --sandbox-dir)
      shift
      sandbox_dir="${1:-}"
      ;;
    --harness)
      shift
      harness="${1:-}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift || true
done

if [ -z "$sandbox_dir" ]; then
  printf '%s\n' 'missing --sandbox-dir' >&2
  usage >&2
  exit 2
fi

case "$harness" in
  pi|pi-tools|pi-message-router|pi-managed-harness|fixture) ;;
  claude|codex|codex-api)
    printf 'terminal-cell smoke does not yet support prompt-bearing %s; use pi first\n' "$harness" >&2
    exit 2
    ;;
  *)
    printf 'unsupported terminal-cell smoke harness: %s\n' "$harness" >&2
    exit 2
    ;;
esac

is_pi_family_harness() {
  case "$harness" in
    pi|pi-tools|pi-message-router|pi-managed-harness) return 0 ;;
    *) return 1 ;;
  esac
}

state_dir="$sandbox_dir/state/terminal-cell"
run_dir="$sandbox_dir/run"
work_dir="$sandbox_dir/work"
artifact_dir="$sandbox_dir/artifacts"
cell_socket="$run_dir/cell.sock"
daemon_ready="$artifact_dir/terminal-cell-daemon.ready"
daemon_stdout="$artifact_dir/terminal-cell-daemon.stdout"
daemon_stderr="$artifact_dir/terminal-cell-daemon.stderr"
run_file="$artifact_dir/terminal-cell-run.nota"
process_file="$artifact_dir/terminal-cell-processes.nota"
socket_file="$artifact_dir/terminal-cell-sockets.nota"
transcript_file="$artifact_dir/terminal-cell-transcript.txt"
prompt_file="$artifact_dir/terminal-cell-prompt.nota"
harness_environment_file="$artifact_dir/harness-environment.nota"
view_once_file="$artifact_dir/terminal-cell-view-once.txt"
attach_stdout="$artifact_dir/host-attach.stdout"
message_command_file="$artifact_dir/pi-message-command.txt"
message_router_inbox_file="$artifact_dir/pi-message-router-inbox.nota"
managed_harness_owner_inbox_file="$artifact_dir/pi-managed-harness-owner-inbox.nota"
manager_socket="$run_dir/persona.sock"
engine_state_root="$sandbox_dir/state/engine"
engine_run_root="$run_dir/e"
engine_daemon_stdout="$artifact_dir/persona-daemon.stdout"
engine_daemon_stderr="$artifact_dir/persona-daemon.stderr"
engine_daemon_pid=""

mkdir -p "$state_dir" "$run_dir" "$work_dir" "$artifact_dir"
rm -f "$cell_socket" "$daemon_ready"
mkfifo "$daemon_ready"

daemon_pid=""

cleanup() {
  status="$?"
  if [ -S "$cell_socket" ]; then
    "$TERMINAL_CELL_CAPTURE" --socket "$cell_socket" >"$transcript_file" 2>/dev/null || true
  fi
  if [ -n "$daemon_pid" ]; then
    kill -- "-$daemon_pid" 2>/dev/null || kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
  fi
  if [ -n "$engine_daemon_pid" ]; then
    kill "$engine_daemon_pid" 2>/dev/null || true
    if [ -d "$engine_state_root/default" ]; then
      for capture in "$engine_state_root/default"/*.env; do
        [ -e "$capture" ] || continue
        process="$(sed -n 's/^process=//p' "$capture" | head -n 1)"
        if [ -n "$process" ]; then
          kill -- "-$process" 2>/dev/null || kill "$process" 2>/dev/null || true
        fi
      done
    fi
    wait "$engine_daemon_pid" 2>/dev/null || true
  fi
  rm -f "$daemon_ready"
  return "$status"
}
trap cleanup EXIT INT TERM

nota_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

write_harness_environment() {
  {
    printf '%s\n' '(HarnessEnvironment'
    printf '  (Harness "%s")\n' "$harness"
    printf '  (TerminalCellDaemon "%s")\n' "$TERMINAL_CELL_DAEMON"
    printf '  (TerminalCellSend "%s")\n' "$TERMINAL_CELL_SEND"
    printf '  (TerminalCellWait "%s")\n' "$TERMINAL_CELL_WAIT"
    printf '  (TerminalCellCapture "%s")\n' "$TERMINAL_CELL_CAPTURE"
    printf '  (TerminalCellView "%s")\n' "$TERMINAL_CELL_VIEW"
    if is_pi_family_harness; then
      printf '  (PiBin "%s")\n' "${PERSONA_PI_BIN:-pi}"
      printf '  (PiPackageDir "%s")\n' "${PI_PACKAGE_DIR:-}"
      printf '  (PiConfigDir "%s")\n' "${PI_CODING_AGENT_DIR:-}"
      printf '  (PiSessionDir "%s")\n' "${PI_CODING_AGENT_SESSION_DIR:-}"
      printf '  (PiProvider "%s")\n' "${PERSONA_PI_PROVIDER:-prometheus}"
      printf '  (PiModel "%s")\n' "${PERSONA_PI_MODEL:-prometheus/qwen3.6-27b}"
      printf '  (PiThinking "%s")\n' "${PERSONA_PI_THINKING:-medium}"
    fi
    printf ')\n'
  } >"$harness_environment_file"
}

fixture_command() {
  child_command=(
    "$PERSONA_BASH"
    -lc
    'printf "fixture-ready\n"; while IFS= read -r line; do printf "fixture-response:%s\n" "$line"; done'
  )
  ready_text="fixture-ready"
  prompt_text="terminal-cell-smoke"
  marker_text="fixture-response:terminal-cell-smoke"
}

resolve_pi_command_settings() {
  pi_bin="${PERSONA_PI_BIN:-pi}"
  if command -v "$pi_bin" >/dev/null 2>&1; then
    pi_bin="$(command -v "$pi_bin")"
  elif [ -x "$pi_bin" ]; then
    :
  else
    printf 'pi not found; set PERSONA_PI_BIN=/path/to/pi\n' >&2
    exit 1
  fi

  pi_provider="${PERSONA_PI_PROVIDER:-prometheus}"
  pi_model="${PERSONA_PI_MODEL:-prometheus/qwen3.6-27b}"
  pi_thinking="${PERSONA_PI_THINKING:-medium}"
}

pi_command() {
  resolve_pi_command_settings
  child_command=(
    "$pi_bin"
    --offline
    --provider
    "$pi_provider"
    --model
    "$pi_model"
    --thinking
    "$pi_thinking"
    --no-tools
    --no-extensions
    --no-skills
    --no-context-files
    --no-session
  )
  ready_text="Pi can explain"
  prompt_text="Reply with the uppercase token whose lowercase spelling is terminal-cell-pi-smoke-ok, replacing each hyphen with an underscore. No other text."
  marker_text="TERMINAL_CELL_PI_SMOKE_OK"
}

write_message_tool() {
  tool_dir="$work_dir/bin"
  mkdir -p "$tool_dir"
  cat >"$tool_dir/message" <<EOF
#!/bin/sh
printf '%s\n' "\$*" > "$message_command_file"
printf '%s\n' '(Accepted (Message pi-tool-proof))'
printf '%s\n' 'MESSAGE_TOOL_PROOF_OK'
EOF
  chmod +x "$tool_dir/message"
  export PATH="$tool_dir:$PATH"
  export PERSONA_MESSAGE_SOCKET="$run_dir/pi-tools-message.sock"
}

wait_for_socket() {
  socket_path="$1"
  label="$2"

  for _attempt in $(seq 1 100); do
    if [ -S "$socket_path" ]; then
      return 0
    fi
    sleep 0.1
  done

  printf 'socket did not appear for %s: %s\n' "$label" "$socket_path" >&2
  return 1
}

start_message_router_engine() {
  : "${PERSONA_DAEMON_BIN:?PERSONA_DAEMON_BIN must point at persona-daemon}"
  : "${PERSONA_MESSAGE_BIN:?PERSONA_MESSAGE_BIN must point at message CLI}"
  : "${PERSONA_ROUTER_EXECUTABLE:?PERSONA_ROUTER_EXECUTABLE must point at persona-router launcher}"
  : "${PERSONA_MESSAGE_DAEMON_EXECUTABLE:?PERSONA_MESSAGE_DAEMON_EXECUTABLE must point at persona-message launcher}"

  mkdir -p "$engine_state_root" "$engine_run_root"
  PERSONA_MANAGER_STORE="$engine_state_root/manager.redb" \
  PERSONA_STATE_ROOT="$engine_state_root" \
  PERSONA_RUN_ROOT="$engine_run_root" \
  PERSONA_ENGINE_TOPOLOGY=message-router \
  PERSONA_ROUTER_EXECUTABLE="$PERSONA_ROUTER_EXECUTABLE" \
  PERSONA_MESSAGE_DAEMON_EXECUTABLE="$PERSONA_MESSAGE_DAEMON_EXECUTABLE" \
    "$PERSONA_DAEMON_BIN" "$manager_socket" \
    >"$engine_daemon_stdout" \
    2>"$engine_daemon_stderr" &
  engine_daemon_pid="$!"

  for _attempt in $(seq 1 100); do
    if grep -Fq "persona-daemon socket=$manager_socket" "$engine_daemon_stdout" 2>/dev/null; then
      break
    fi
    if ! kill -0 "$engine_daemon_pid" 2>/dev/null; then
      cat "$engine_daemon_stdout" >&2 || true
      cat "$engine_daemon_stderr" >&2 || true
      exit 1
    fi
    sleep 0.1
  done
  grep -Fq "persona-daemon socket=$manager_socket" "$engine_daemon_stdout"
  wait_for_socket "$engine_run_root/default/message.sock" "persona-message"
  wait_for_socket "$engine_run_root/default/router.sock" "persona-router"
}

start_managed_harness_engine() {
  : "${PERSONA_DAEMON_BIN:?PERSONA_DAEMON_BIN must point at persona-daemon}"
  : "${PERSONA_MESSAGE_BIN:?PERSONA_MESSAGE_BIN must point at message CLI}"
  : "${PERSONA_TERMINAL_SIGNAL_BIN:?PERSONA_TERMINAL_SIGNAL_BIN must point at persona-terminal-signal}"
  : "${PERSONA_THREE_HARNESS_LAUNCHERS:?PERSONA_THREE_HARNESS_LAUNCHERS must point at three-harness launchers}"

  mkdir -p "$engine_state_root" "$engine_run_root"
  PERSONA_MANAGER_STORE="$engine_state_root/manager.redb" \
  PERSONA_STATE_ROOT="$engine_state_root" \
  PERSONA_RUN_ROOT="$engine_run_root" \
  PERSONA_ENGINE_TOPOLOGY=three-harness-chain \
  PERSONA_ROUTER_EXECUTABLE="$PERSONA_THREE_HARNESS_LAUNCHERS/bin/persona-router-prototype-launcher" \
  PERSONA_HARNESS_EXECUTABLE="$PERSONA_THREE_HARNESS_LAUNCHERS/bin/persona-harness-prototype-launcher" \
  PERSONA_TERMINAL_EXECUTABLE="$PERSONA_THREE_HARNESS_LAUNCHERS/bin/persona-three-harness-terminal-launcher" \
  PERSONA_MESSAGE_DAEMON_EXECUTABLE="$PERSONA_THREE_HARNESS_LAUNCHERS/bin/persona-message-prototype-launcher" \
    "$PERSONA_DAEMON_BIN" "$manager_socket" \
    >"$engine_daemon_stdout" \
    2>"$engine_daemon_stderr" &
  engine_daemon_pid="$!"

  for _attempt in $(seq 1 100); do
    if grep -Fq "persona-daemon socket=$manager_socket" "$engine_daemon_stdout" 2>/dev/null; then
      break
    fi
    if ! kill -0 "$engine_daemon_pid" 2>/dev/null; then
      cat "$engine_daemon_stdout" >&2 || true
      cat "$engine_daemon_stderr" >&2 || true
      exit 1
    fi
    sleep 0.1
  done
  grep -Fq "persona-daemon socket=$manager_socket" "$engine_daemon_stdout"
  wait_for_socket "$engine_run_root/default/message.sock" "persona-message"
  wait_for_socket "$engine_run_root/default/router.sock" "persona-router"

  for agent in initiator responder reviewer; do
    wait_for_managed_terminal_text "$agent" "$agent-runner-ready"
  done
}

write_real_message_tool() {
  tool_dir="$work_dir/bin"
  mkdir -p "$tool_dir"
  cat >"$tool_dir/message" <<EOF
#!/bin/sh
printf '%s\n' "\$*" > "$message_command_file"
exec "$PERSONA_MESSAGE_BIN" "\$@"
EOF
  chmod +x "$tool_dir/message"
  export PATH="$tool_dir:$PATH"
  export PERSONA_MESSAGE_SOCKET="$engine_run_root/default/message.sock"
}

pi_tools_command() {
  resolve_pi_command_settings
  write_message_tool
  child_command=(
    "$pi_bin"
    --offline
    --provider
    "$pi_provider"
    --model
    "$pi_model"
    --thinking
    "$pi_thinking"
    --tools
    bash
    --no-extensions
    --no-skills
    --no-context-files
    --no-session
  )
  ready_text="Pi can explain"
  prompt_text="Use the bash tool to run exactly: message '(Send operator pi-tool-proof)'. After the command finishes, answer MESSAGE_TOOL_DONE."
  marker_text="MESSAGE_TOOL_PROOF_OK"
}

pi_message_router_command() {
  resolve_pi_command_settings
  start_message_router_engine
  write_real_message_tool
  child_command=(
    "$pi_bin"
    --offline
    --provider
    "$pi_provider"
    --model
    "$pi_model"
    --thinking
    "$pi_thinking"
    --tools
    bash
    --no-extensions
    --no-skills
    --no-context-files
    --no-session
  )
  ready_text="Pi can explain"
  prompt_text='Use the bash tool to run exactly: message '\''(Send responder "pi routed proof")'\''. After the command finishes, answer MESSAGE_ROUTER_DONE.'
  marker_text="SubmissionAccepted"
}

capture_managed_terminal() {
  agent="$1"
  output="$artifact_dir/pi-managed-harness-$agent.capture.tsv"
  "$PERSONA_TERMINAL_SIGNAL_BIN" \
    --control-socket "$engine_run_root/default/$agent-terminal.sock" \
    --terminal "$agent" \
    capture \
    >"$output"
  grep -Fq "TerminalCaptured	$agent	1" "$output"
}

managed_terminal_capture_contains_text() {
  capture_file="$1"
  text="$2"
  hex="$(printf '%s' "$text" | od -An -tx1 -v | tr -d ' \n')"
  grep -Fq "$hex" "$capture_file"
}

wait_for_managed_terminal_text() {
  agent="$1"
  text="$2"
  output="$artifact_dir/pi-managed-harness-$agent.capture.tsv"
  for _attempt in $(seq 1 100); do
    capture_managed_terminal "$agent"
    if managed_terminal_capture_contains_text "$output" "$text"; then
      return 0
    fi
    sleep 0.1
  done
  printf 'managed terminal %s never captured text: %s\n' "$agent" "$text" >&2
  cat "$output" >&2 || true
  return 1
}

wait_for_managed_owner_inbox() {
  for _attempt in $(seq 1 100); do
    PERSONA_MESSAGE_SOCKET="$engine_run_root/default/message.sock" \
      "$PERSONA_MESSAGE_BIN" \
        '(Inbox owner)' \
        >"$managed_harness_owner_inbox_file"
    if grep -Fq 'reviewer "reviewer completed task"' "$managed_harness_owner_inbox_file"; then
      return 0
    fi
    sleep 0.1
  done
  cat "$managed_harness_owner_inbox_file" >&2 || true
  return 1
}

pi_managed_harness_command() {
  resolve_pi_command_settings
  start_managed_harness_engine
  write_real_message_tool
  child_command=(
    "$pi_bin"
    --offline
    --provider
    "$pi_provider"
    --model
    "$pi_model"
    --thinking
    "$pi_thinking"
    --tools
    bash
    --no-extensions
    --no-skills
    --no-context-files
    --no-session
  )
  ready_text="Pi can explain"
  prompt_text="Use the bash tool to run exactly: message '(Send initiator start-three-harness-task)'. After the command finishes, answer MANAGED_HARNESS_DONE."
  marker_text="SubmissionAccepted"
}

case "$harness" in
  fixture) fixture_command ;;
  pi) pi_command ;;
  pi-tools) pi_tools_command ;;
  pi-message-router) pi_message_router_command ;;
  pi-managed-harness) pi_managed_harness_command ;;
esac

write_harness_environment

{
  printf '%s\n' '(TerminalCellPrompt'
  printf '  (Harness "%s")\n' "$harness"
  printf '  (Prompt "%s")\n' "$prompt_text"
  printf '  (ExpectedMarker "%s")\n' "$marker_text"
  printf ')\n'
} >"$prompt_file"

setsid "$TERMINAL_CELL_DAEMON" \
  --socket "$cell_socket" \
  -- "$PERSONA_BASH" -lc 'cd "$1" || exit; shift; exec "$@"' terminal-cell-smoke "$work_dir" "${child_command[@]}" \
  >"$daemon_ready" 2>"$daemon_stderr" &
daemon_pid="$!"

if ! ready_line="$(timeout 20s head -n 1 "$daemon_ready")"; then
  printf '%s\n' 'terminal-cell daemon did not announce readiness' >&2
  exit 1
fi
printf '%s\n' "$ready_line" >"$daemon_stdout"

timeout 90s "$TERMINAL_CELL_WAIT" --socket "$cell_socket" --text "$ready_text"
"$TERMINAL_CELL_VIEW" --socket "$cell_socket" --once >"$view_once_file"
TERMINAL_CELL_VIEW="$TERMINAL_CELL_VIEW" \
  "$PERSONA_ENGINE_SANDBOX_ATTACH" --dry-run --sandbox-dir "$sandbox_dir" >"$attach_stdout"
"$TERMINAL_CELL_SEND" --socket "$cell_socket" --line "$prompt_text"
timeout 420s "$TERMINAL_CELL_WAIT" --socket "$cell_socket" --text "$marker_text"
"$TERMINAL_CELL_CAPTURE" --socket "$cell_socket" >"$transcript_file"

if [ "$harness" = "pi-tools" ]; then
  test -f "$message_command_file"
  grep -Fq "(Send operator pi-tool-proof)" "$message_command_file"
fi

if [ "$harness" = "pi-message-router" ]; then
  test -f "$message_command_file"
  grep -Fq '(Send responder "pi routed proof")' "$message_command_file"
  PERSONA_MESSAGE_SOCKET="$engine_run_root/default/message.sock" \
    "$PERSONA_MESSAGE_BIN" '(Inbox responder)' >"$message_router_inbox_file"
  grep -Fq "pi routed proof" "$message_router_inbox_file"
fi

if [ "$harness" = "pi-managed-harness" ]; then
  test -f "$message_command_file"
  grep -Fq '(Send initiator start-three-harness-task)' "$message_command_file"
  wait_for_managed_owner_inbox
  wait_for_managed_terminal_text initiator "initiator-received:start-three-harness-task"
  wait_for_managed_terminal_text initiator "initiator-sent:initiator handed to responder"
  wait_for_managed_terminal_text responder "responder-received:initiator handed to responder"
  wait_for_managed_terminal_text responder "responder-sent:responder handed to reviewer"
  wait_for_managed_terminal_text reviewer "reviewer-received:responder handed to reviewer"
  wait_for_managed_terminal_text reviewer "reviewer-sent:reviewer completed task"
fi

keep_seconds="${PERSONA_TERMINAL_CELL_KEEP_SECONDS:-0}"
if [ "$keep_seconds" != "0" ]; then
  sleep "$keep_seconds"
fi

{
  printf '%s\n' '(TerminalCellRun'
  printf '  (Mode LiveAgentSmoke)\n'
  printf '  (Harness "%s")\n' "$harness"
  printf '  (Status Passed)\n'
  printf '  (Transcript "%s")\n' "$transcript_file"
  if [ "$harness" = "pi-message-router" ]; then
    printf '  (MessageRouterInbox "%s")\n' "$message_router_inbox_file"
  fi
  if [ "$harness" = "pi-managed-harness" ]; then
    printf '  (ManagedHarnessOwnerInbox "%s")\n' "$managed_harness_owner_inbox_file"
  fi
  printf ')\n'
} >"$run_file"

{
  printf '%s\n' '(TerminalCellProcesses'
  printf '  (DaemonPid %s)\n' "$daemon_pid"
  printf '%s\n' '  (ChildCommand'
  for part in "${child_command[@]}"; do
    printf '    '
    nota_string "$part"
    printf '\n'
  done
  printf '  )\n'
  printf ')\n'
} >"$process_file"

{
  printf '%s\n' '(TerminalCellSockets'
  printf '  (CellSocket "%s")\n' "$cell_socket"
  printf ')\n'
} >"$socket_file"

printf 'persona-engine-sandbox-terminal-cell-smoke passed\n'
printf 'socket=%s\n' "$cell_socket"
printf 'transcript=%s\n' "$transcript_file"

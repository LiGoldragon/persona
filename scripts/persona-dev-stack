#!/usr/bin/env bash
set -euo pipefail

: "${PERSONA_MESSAGE_PACKAGE:?PERSONA_MESSAGE_PACKAGE must point at the built persona-message package}"
: "${PERSONA_ROUTER_PACKAGE:?PERSONA_ROUTER_PACKAGE must point at the built persona-router package}"
: "${PERSONA_TERMINAL_PACKAGE:?PERSONA_TERMINAL_PACKAGE must point at the built persona-terminal package}"
: "${PERSONA_BASH:?PERSONA_BASH must point at bash}"

mode="${1:-run}"
if [ "$mode" = "run" ] || [ "$mode" = "smoke" ]; then
  shift || true
else
  printf 'usage: persona-dev-stack [run|smoke]\n' >&2
  exit 2
fi

root="${PERSONA_STACK_ROOT:-$(mktemp -d -t persona-dev-stack.XXXXXX)}"
mkdir -p "$root"

router_socket="$root/router.sock"
message_socket="$root/message.sock"
terminal_socket="$root/responder.terminal.control.sock"
terminal_data_socket="$root/responder.terminal.data.sock"
harness_socket="$root/responder.harness.sock"
router_store="$root/router.redb"
terminal_store="$root/terminal.redb"
message_store="$root/message-store"
router_bootstrap="$root/router-bootstrap.nota"
router_daemon_configuration="$root/router-daemon.nota"
router_supervision_socket="$root/router.supervision.sock"
message_spawn_envelope="$root/message.envelope"
message_daemon_configuration="$root/message-daemon.nota"
router_stdout="$root/router.stdout"
router_stderr="$root/router.stderr"
message_daemon_stdout="$root/message-daemon.stdout"
message_daemon_stderr="$root/message-daemon.stderr"
harness_stdout="$root/harness.stdout"
harness_stderr="$root/harness.stderr"
terminal_stdout="$root/terminal.stdout"
terminal_stderr="$root/terminal.stderr"
environment_file="$root/env.sh"
process_manifest="$root/process-manifest.nota"
socket_manifest="$root/socket-manifest.nota"

message_bin="$PERSONA_MESSAGE_PACKAGE/bin/message"
message_daemon_bin="$PERSONA_MESSAGE_PACKAGE/bin/persona-message-daemon"
router_bin="$PERSONA_ROUTER_PACKAGE/bin/persona-router-daemon"
terminal_daemon="$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-daemon"
terminal_signal="$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-signal"
if [ -n "${PERSONA_HARNESS_PACKAGE:-}" ]; then
  harness_daemon="$PERSONA_HARNESS_PACKAGE/bin/persona-harness-daemon"
else
  harness_daemon=""
fi

cleanup() {
  if [ -n "${terminal_pid:-}" ]; then
    kill "$terminal_pid" 2>/dev/null || true
    wait "$terminal_pid" 2>/dev/null || true
  fi
  if [ -n "${message_daemon_pid:-}" ]; then
    kill "$message_daemon_pid" 2>/dev/null || true
    wait "$message_daemon_pid" 2>/dev/null || true
  fi
  if [ -n "${harness_pid:-}" ]; then
    kill "$harness_pid" 2>/dev/null || true
    wait "$harness_pid" 2>/dev/null || true
  fi
  if [ -n "${router_pid:-}" ]; then
    kill "$router_pid" 2>/dev/null || true
    wait "$router_pid" 2>/dev/null || true
  fi

  if [ "${PERSONA_STACK_KEEP_ARTIFACTS:-1}" = "1" ]; then
    printf 'persona dev stack artifacts=%s\n' "$root"
  else
    rm -rf "$root"
  fi
}
trap cleanup EXIT INT TERM

read_ready_line() {
  local name="$1"
  local fd="$2"
  local output_file="$3"
  local expected="$4"
  local line

  if ! IFS= read -r -t 10 -u "$fd" line; then
    printf '%s did not report readiness\n' "$name" >&2
    return 1
  fi
  printf '%s\n' "$line" >"$output_file"
  if [ "$line" != "$expected" ]; then
    printf '%s reported unexpected readiness line: %s\n' "$name" "$line" >&2
    return 1
  fi
}

capture_contains_text() {
  local capture_file="$1"
  local text="$2"
  local hex

  hex="$(printf '%s' "$text" | od -An -tx1 -v | tr -d ' \n')"
  grep -Fq "$hex" "$capture_file"
}

start_router() {
  write_router_daemon_configuration
  coproc PERSONA_ROUTER_PROCESS { "$router_bin" "$router_daemon_configuration" 2>&1; }
  router_pid="$PERSONA_ROUTER_PROCESS_PID"
  read_ready_line "persona-router" "${PERSONA_ROUTER_PROCESS[0]}" "$router_stdout" "persona-router-daemon socket=$router_socket"
}

start_message_daemon() {
  write_message_spawn_envelope
  write_message_daemon_configuration
  coproc PERSONA_MESSAGE_DAEMON_PROCESS {
    "$message_daemon_bin" "$message_daemon_configuration" 2>&1
  }
  message_daemon_pid="$PERSONA_MESSAGE_DAEMON_PROCESS_PID"
  read_ready_line "persona-message-daemon" "${PERSONA_MESSAGE_DAEMON_PROCESS[0]}" "$message_daemon_stdout" "persona-message-daemon socket=$message_socket"
}

start_harness() {
  coproc PERSONA_HARNESS_PROCESS {
    "$harness_daemon" \
      --socket "$harness_socket" \
      --harness responder \
      --terminal-socket "$terminal_socket" \
      2>&1
  }
  harness_pid="$PERSONA_HARNESS_PROCESS_PID"
  read_ready_line "persona-harness" "${PERSONA_HARNESS_PROCESS[0]}" "$harness_stdout" "persona-harness-daemon socket=$harness_socket"
}

start_terminal() {
  coproc PERSONA_TERMINAL_PROCESS {
    "$terminal_daemon" \
      --store "$terminal_store" \
      --name responder \
      --control-socket "$terminal_socket" \
      --data-socket "$terminal_data_socket" \
      -- "$PERSONA_BASH" -lc 'printf "terminal-ready\n"; while IFS= read -r line; do printf "terminal-echo:%s\n" "$line"; done' \
      2>"$terminal_stderr"
  }
  terminal_pid="$PERSONA_TERMINAL_PROCESS_PID"
  read_ready_line "persona-terminal" "${PERSONA_TERMINAL_PROCESS[0]}" "$terminal_stdout" "persona-terminal-daemon control-socket=$terminal_socket data-socket=$terminal_data_socket"
}

write_router_bootstrap() {
  {
    if [ -n "$harness_daemon" ]; then
      printf '(RegisterActor (Actor responder %s (EndpointTransport HarnessSocket "%s" None)))\n' "$harness_pid" "$harness_socket"
    else
      printf '(RegisterActor (Actor responder %s (EndpointTransport PtySocket "%s" None)))\n' "$terminal_pid" "$terminal_socket"
    fi
    printf '%s\n' '(GrantDirectMessage owner responder)'
  } >"$router_bootstrap"
}

write_message_spawn_envelope() {
  local owner_user_id
  owner_user_id="$(id -u)"
  printf '(SpawnEnvelope dev-stack Message Message (UnixUser %s) "%s" "%s" 432 "%s" 384 [(PeerSocket Router "%s")] "%s" 1)\n' \
    "$owner_user_id" \
    "$root" \
    "$message_socket" \
    "$root/message.supervision.sock" \
    "$router_socket" \
    "$root/persona.sock" \
    >"$message_spawn_envelope"
}

write_router_daemon_configuration() {
  local owner_user_id
  owner_user_id="$(id -u)"
  # RouterDaemonConfiguration per signal-persona-router:
  # router_socket_path router_socket_mode supervision_socket_path
  # supervision_socket_mode store_path bootstrap_path owner_identity
  # `Option<WirePath>` encodes as the inner value when Some.
  printf '(RouterDaemonConfiguration "%s" 384 "%s" 384 "%s" "%s" (UnixUser %s))\n' \
    "$router_socket" \
    "$router_supervision_socket" \
    "$router_store" \
    "$router_bootstrap" \
    "$owner_user_id" \
    >"$router_daemon_configuration"
}

write_message_daemon_configuration() {
  local owner_user_id
  owner_user_id="$(id -u)"
  # MessageDaemonConfiguration record per signal-persona-message:
  # message_socket_path message_socket_mode supervision_socket_path
  # supervision_socket_mode router_socket_path component_ingresses owner_identity
  printf '(MessageDaemonConfiguration "%s" 432 "%s" 384 "%s" [] (UnixUser %s))\n' \
    "$message_socket" \
    "$root/message.supervision.sock" \
    "$router_socket" \
    "$owner_user_id" \
    >"$message_daemon_configuration"
}

write_environment_file() {
  cat >"$environment_file" <<EOF
export PERSONA_MESSAGE_SOCKET='$message_socket'
export PERSONA_MESSAGE_ROUTER_SOCKET='$router_socket'
export PERSONA_MESSAGE_STORE='$message_store'
export PERSONA_ROUTER_STORE='$router_store'
$(if [ -n "$harness_daemon" ]; then printf "export PERSONA_HARNESS_SOCKET='%s'\n" "$harness_socket"; fi)
export PERSONA_TERMINAL_SOCKET='$terminal_socket'
export PERSONA_TERMINAL_STORE='$terminal_store'
export PATH='$PERSONA_MESSAGE_PACKAGE/bin:$PERSONA_ROUTER_PACKAGE/bin:$(if [ -n "${PERSONA_HARNESS_PACKAGE:-}" ]; then printf "%s/bin:" "$PERSONA_HARNESS_PACKAGE"; fi)$PERSONA_TERMINAL_PACKAGE/bin:'"\$PATH"
EOF
}

write_stack_manifests() {
  {
    printf '%s\n' '(PersonaDevStackProcesses'
    printf '  (Root "%s")\n' "$root"
    printf '  (RouterPid %s)\n' "$router_pid"
    printf '  (MessageDaemonPid %s)\n' "$message_daemon_pid"
    printf '  (MessageSpawnEnvelope "%s")\n' "$message_spawn_envelope"
    if [ -n "$harness_daemon" ]; then
      printf '  (HarnessPid %s)\n' "$harness_pid"
    fi
    printf '  (TerminalPid %s)\n' "$terminal_pid"
    printf '  (RouterReady "%s")\n' "$router_stdout"
    printf '  (MessageDaemonReady "%s")\n' "$message_daemon_stdout"
    if [ -n "$harness_daemon" ]; then
      printf '  (HarnessReady "%s")\n' "$harness_stdout"
    fi
    printf '  (TerminalReady "%s")\n' "$terminal_stdout"
    printf ')\n'
  } >"$process_manifest"

  {
    printf '%s\n' '(PersonaDevStackSockets'
    printf '  (Root "%s")\n' "$root"
    printf '  (RouterSocket "%s")\n' "$router_socket"
    printf '  (MessageSocket "%s")\n' "$message_socket"
    printf '  (MessageSpawnEnvelope "%s")\n' "$message_spawn_envelope"
    printf '  (RouterStore "%s")\n' "$router_store"
    if [ -n "$harness_daemon" ]; then
      printf '  (HarnessSocket "%s")\n' "$harness_socket"
    fi
    printf '  (TerminalSocket "%s")\n' "$terminal_socket"
    printf '  (TerminalStore "%s")\n' "$terminal_store"
    printf '  (MessageStore "%s")\n' "$message_store"
    printf '  (RouterBootstrap "%s")\n' "$router_bootstrap"
    printf ')\n'
  } >"$socket_manifest"
}

run_smoke() {
  local send_output="$root/message-send.nota"
  local send_error="$root/message-send.stderr"
  local inbox_output="$root/message-inbox.nota"
  local inbox_error="$root/message-inbox.stderr"
  local terminal_connect="$root/terminal-connect.tsv"
  local terminal_input="$root/terminal-input.tsv"
  local terminal_capture="$root/terminal-capture.tsv"
  local terminal_capture_after_input="$root/terminal-capture-after-input.tsv"

  "$terminal_signal" --control-socket "$terminal_socket" --terminal responder connect >"$terminal_connect"
  grep -Fq $'TerminalReady\tresponder\t1' "$terminal_connect"

  PERSONA_MESSAGE_SOCKET="$message_socket" \
    PERSONA_MESSAGE_STORE="$message_store" \
    "$message_bin" '(Send responder "hello from persona meta")' \
    >"$send_output" 2>"$send_error"
  grep -Fq "(SubmissionAccepted " "$send_output"

  "$terminal_signal" --control-socket "$terminal_socket" --terminal responder capture >"$terminal_capture"
  grep -Fq $'TerminalCaptured\tresponder\t1' "$terminal_capture"
  capture_contains_text "$terminal_capture" "hello from persona meta"

  PERSONA_MESSAGE_SOCKET="$message_socket" \
    PERSONA_MESSAGE_STORE="$message_store" \
    "$message_bin" '(Inbox responder)' \
    >"$inbox_output" 2>"$inbox_error"
  if grep -Fq "hello from persona meta" "$inbox_output"; then
    printf 'delivered message remained in router inbox\n' >&2
    return 1
  fi

  if [ ! -f "$router_store" ]; then
    printf 'router store was not created: %s\n' "$router_store" >&2
    return 1
  fi

  "$terminal_signal" --control-socket "$terminal_socket" --terminal responder prompt terminal-side-input >"$terminal_input"
  grep -Fq $'TerminalInputAccepted\tresponder\t1' "$terminal_input"

  "$terminal_signal" --control-socket "$terminal_socket" --terminal responder capture >"$terminal_capture_after_input"
  grep -Fq $'TerminalCaptured\tresponder\t1' "$terminal_capture_after_input"
  capture_contains_text "$terminal_capture_after_input" "terminal-side-input"

  printf 'persona dev stack smoke=passed\n'
  printf 'router send=%s\n' "$send_output"
  printf 'router inbox=%s\n' "$inbox_output"
  printf 'router store=%s\n' "$router_store"
  printf 'terminal capture=%s\n' "$terminal_capture"
  printf 'terminal capture after input=%s\n' "$terminal_capture_after_input"
}

start_terminal
if [ -n "$harness_daemon" ]; then
  start_harness
fi
write_router_bootstrap
start_router
start_message_daemon
write_environment_file
write_stack_manifests

case "$mode" in
  smoke)
    run_smoke
    ;;
  run)
    printf 'persona dev stack root=%s\n' "$root"
    printf 'environment=%s\n' "$environment_file"
    printf 'process manifest=%s\n' "$process_manifest"
    printf 'socket manifest=%s\n' "$socket_manifest"
    printf 'router socket=%s\n' "$router_socket"
    printf 'message socket=%s\n' "$message_socket"
    if [ -n "$harness_daemon" ]; then
      printf 'harness socket=%s\n' "$harness_socket"
    fi
    printf 'terminal socket=%s\n' "$terminal_socket"
    printf 'try: source %s\n' "$environment_file"
    printf 'try: message '\''(Send responder "hello")'\''\n'
    printf 'try: message '\''(Inbox responder)'\''\n'
    printf 'try: persona-terminal-signal --control-socket "$PERSONA_TERMINAL_SOCKET" --terminal responder capture\n'
    if [ -n "$harness_daemon" ]; then
      wait -n "$router_pid" "$message_daemon_pid" "$harness_pid" "$terminal_pid"
    else
      wait -n "$router_pid" "$message_daemon_pid" "$terminal_pid"
    fi
    ;;
esac
